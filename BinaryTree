class BinaryTree():
  def __init__(self,data):
    self.data=data
    self.left=None 
    self.right=None 
  
  def addChild(self,value):
    if value==self.data:
      return
    if value<self.data:
      if self.left:
        self.left.addChild(value)
      else:
        self.left=BinaryTree(value)
    else:
      if self.right:
        self.right.addChild(value)
      else:
        self.right=BinaryTree(value)
      
  def inOrder(self):
    final=[]
    if self.left:
      xx=self.left.inOrder()
      final+=xx
    final.append(self.data)
    if self.right:
      yy=self.right.inOrder()
      final+=yy
    return final
arr=[17,4,20,1,9,18,23,34]
obj=BinaryTree(17)
for i in range(1,len(arr)):
  obj.addChild(arr[i])
print(obj.inOrder())
